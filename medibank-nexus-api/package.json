{
  "name": "medibank-nexus-api",
  "version": "1.0.0",
  "description": "MediBank Nexus — Express REST API",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev":              "nodemon src/index.js",
    "start":            "node src/index.js",
    "db:migrate":       "node scripts/migrate.js",
    "db:migrate:reset": "node scripts/migrate.js --reset",
    "db:seed":          "node scripts/seed.js",
    "audit:check":      "npm audit --audit-level=high"
  },
  "dependencies": {
    "bcrypt":              "^5.1.1",
    "cors":                "^2.8.5",
    "dotenv":              "^16.4.5",
    "express":             "^4.19.2",
    "express-rate-limit":  "^7.3.1",
    "express-validator":   "^7.1.0",
    "helmet":              "^7.1.0",
    "hpp":                 "^0.2.3",
    "ioredis":             "^5.3.2",
    "jsonwebtoken":        "^9.0.2",
    "knex":                "^3.1.0",
    "morgan":              "^1.10.0",
    "pg":                  "^8.12.0",
    "rate-limit-redis":    "^4.2.0",
    "uuid":                "^10.0.0",
    "xss-clean":           "^0.1.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "nodemonConfig": {
    "ext":   "js",
    "watch": ["src"]
  }
}
