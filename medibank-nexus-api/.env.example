# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medibank
DB_USER=postgres
DB_PASSWORD=your_strong_db_password_here

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret
JWT_EXPIRES_IN=8h

# Refresh token secret (different from access token)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Field-Level Encryption (AES-256-GCM) ─────────────────────────────────────
# CRITICAL: Must be exactly 32 bytes (64 hex chars). Back this up securely.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_32_byte_hex_key_64_chars_exactly

# ── Redis (token blacklist, rate limiting, lockout) ───────────────────────────
REDIS_URL=redis://localhost:6379
# For Redis with password: redis://:yourpassword@localhost:6379
# For Redis TLS (production): rediss://...

# ── AI Providers (platform keys — users can supply their own via Settings) ────
ANTHROPIC_API_KEY=sk-ant-your_key_here
# OpenAI — required if you want GPT-4o support without users supplying their own key
OPENAI_API_KEY=sk-your_openai_key_here
# Google AI (Gemini) — required for Gemini support
GOOGLE_AI_API_KEY=AIzaSy-your_google_ai_key_here

# ── Google OAuth2 (for Calendar, Drive, Docs integration) ─────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Add redirect URI: http://localhost:3001/api/v1/integrations/google/oauth-callback
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/integrations/google/oauth-callback

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development    # Set to 'production' on live server
API_BASE_URL=http://localhost:3001

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production
CLIENT_ORIGIN=http://localhost:5173

# ── Security ──────────────────────────────────────────────────────────────────
# Max failed login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5
# Lockout duration in minutes
LOCKOUT_DURATION_MINUTES=15
# General API rate limit (requests per 15 min window per IP)
RATE_LIMIT_GENERAL=100
# Auth endpoint rate limit (attempts per 15 min window per IP)
RATE_LIMIT_AUTH=10
